#!/bin/bash
# Commit message hook for agent-first projects
# Validates commit message format using industry-standard Conventional Commits
#
# Enforces Conventional Commits format without requiring npm/husky.
# Works with any language/framework (Go, Python, Rust, etc.)
#
# Install: cp assets/git-hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Skip validation for merge commits, revert commits
if echo "$COMMIT_MSG" | grep -qE '^(Merge|Revert)'; then
    exit 0
fi

# Check 1: Minimum length (10 characters)
if [ ${#COMMIT_MSG} -lt 10 ]; then
    echo -e "${RED}❌ Commit message too short (min 10 chars)${NC}"
    echo -e "${YELLOW}Current: \"$COMMIT_MSG\"${NC}"
    exit 1
fi

# Check 2: No AI tool names in commit message (except Co-Authored-By trailers)
# Remove Co-Authored-By lines before checking for AI names
COMMIT_MSG_WITHOUT_COAUTHORS=$(echo "$COMMIT_MSG" | grep -viE '^Co-Authored-By:')
if echo "$COMMIT_MSG_WITHOUT_COAUTHORS" | grep -qiE '(claude|chatgpt|copilot|cursor|sonnet|haiku|opus)'; then
    echo -e "${RED}❌ Remove AI tool names from commit message${NC}"
    echo -e "${YELLOW}Current: \"$COMMIT_MSG\"${NC}"
    echo -e "${YELLOW}Agents should describe WHAT changed, not WHO wrote it${NC}"
    echo -e "${YELLOW}Note: Co-Authored-By trailers are allowed${NC}"
    exit 1
fi

# Check 3: Conventional Commits format (optional but recommended)
# Format: <type>(<scope>): <subject>
# Example: feat(auth): add JWT token refresh
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .+'; then
    echo -e "${YELLOW}⚠️  Commit message doesn't follow Conventional Commits${NC}"
    echo -e "${YELLOW}Current: \"$COMMIT_MSG\"${NC}"
    echo ""
    echo -e "${YELLOW}Recommended format:${NC}"
    echo -e "  ${GREEN}feat(auth): add JWT token refresh${NC}"
    echo -e "  ${GREEN}fix(db): prevent race condition in connection pool${NC}"
    echo -e "  ${GREEN}docs(arch): update service dependencies diagram${NC}"
    echo ""
    echo -e "${YELLOW}Types: feat, fix, docs, style, refactor, test, chore, perf, ci${NC}"
    echo ""
    # Warning only, don't block (set to exit 1 to enforce)
fi

# Check 4: First line should be <= 72 characters
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo -e "${YELLOW}⚠️  First line is ${#FIRST_LINE} chars (recommended: ≤72)${NC}"
    echo -e "${YELLOW}Keep subject concise, use body for details${NC}"
fi

# Check 5: No trailing whitespace
if echo "$COMMIT_MSG" | grep -q '[[:space:]]$'; then
    echo -e "${YELLOW}⚠️  Commit message has trailing whitespace${NC}"
fi

# Check 6: Subject should not end with period
if echo "$FIRST_LINE" | grep -q '\.$'; then
    echo -e "${YELLOW}⚠️  Subject line should not end with period${NC}"
fi

# Check 7: Subject should start with lowercase (after type prefix)
SUBJECT=$(echo "$FIRST_LINE" | sed -E 's/^[a-z]+(\([^)]+\))?:\s*//')
if echo "$SUBJECT" | grep -qE '^[A-Z]'; then
    echo -e "${YELLOW}⚠️  Subject should start with lowercase${NC}"
    echo -e "${YELLOW}Current: \"$FIRST_LINE\"${NC}"
    echo -e "${YELLOW}Better:  \"$(echo $FIRST_LINE | sed 's/:\s*[A-Z]/: \L&/')\"${NC}"
fi

# Check 8: Blank line between subject and body (if body exists)
if [ $(echo "$COMMIT_MSG" | wc -l) -gt 1 ]; then
    SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n '2p')
    if [ -n "$SECOND_LINE" ]; then
        echo -e "${YELLOW}⚠️  Add blank line between subject and body${NC}"
    fi
fi

echo -e "${GREEN}✅ Commit message validated${NC}"
exit 0
