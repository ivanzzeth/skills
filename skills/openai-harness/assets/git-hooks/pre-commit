#!/bin/bash
# Pre-commit hook for agent-first projects
# Runs fast local checks before allowing commit
#
# Install: cp assets/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or use: ./scripts/install_hooks.sh

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}Running pre-commit checks...${NC}"

# 1. Check for AGENTS.md size (if it exists)
if [ -f "AGENTS.md" ]; then
    AGENTS_LINES=$(wc -l < AGENTS.md)
    if [ $AGENTS_LINES -gt 200 ]; then
        echo -e "${YELLOW}⚠️  AGENTS.md has $AGENTS_LINES lines (target: ~100)${NC}"
        echo -e "${YELLOW}   Consider running: ./scripts/migrate_from_monolith.py AGENTS.md${NC}"
    fi
fi

# 2. Check for secrets in staged files
echo -e "${BLUE}Checking for secrets...${NC}"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        # Skip .harness/ directory (contains security check patterns as examples)
        if echo "$FILE" | grep -qE '^\.harness/'; then
            continue
        fi

        # Check for common secret patterns
        if grep -qE '(password|api[_-]?key|secret|token)\s*=\s*["\047][^"\047$]{16,}["\047]' "$FILE" 2>/dev/null; then
            echo -e "${RED}❌ Potential secret detected in: $FILE${NC}"
            echo -e "${RED}   Remove secrets before committing${NC}"
            exit 1
        fi

        # Check for AWS keys
        if grep -qE 'AKIA[0-9A-Z]{16}' "$FILE" 2>/dev/null; then
            echo -e "${RED}❌ AWS access key detected in: $FILE${NC}"
            exit 1
        fi

        # Check for private keys
        if grep -q "BEGIN.*PRIVATE KEY" "$FILE" 2>/dev/null; then
            echo -e "${RED}❌ Private key detected in: $FILE${NC}"
            exit 1
        fi
    fi
done

# 3. Check for critical TODOs in staged code
echo -e "${BLUE}Checking for critical TODOs...${NC}"
if [ -f "scripts/lint/code_todos.py" ]; then
    STAGED_CODE=$(echo "$STAGED_FILES" | grep -E '\.(go|py|js|ts|tsx|jsx|rs|java|cpp|c|h)$' || true)

    if [ -n "$STAGED_CODE" ]; then
        for FILE in $STAGED_CODE; do
            if [ -f "$FILE" ]; then
                # Check for BUG or FIXME in staged files
                if grep -qE '\b(BUG|FIXME)[:\s-]' "$FILE" 2>/dev/null; then
                    echo -e "${YELLOW}⚠️  Found BUG/FIXME in: $FILE${NC}"
                    grep -nE '\b(BUG|FIXME)[:\s-]' "$FILE" || true
                    echo -e "${YELLOW}   Consider fixing before commit${NC}"
                fi
            fi
        done
    fi
fi

# 4. Validate documentation if docs changed
DOCS_CHANGED=$(echo "$STAGED_FILES" | grep -E '^docs/|^AGENTS\.md|^ARCHITECTURE\.md' || true)
if [ -n "$DOCS_CHANGED" ] && [ -f "scripts/lint/validate_docs.py" ]; then
    echo -e "${BLUE}Validating documentation...${NC}"
    if ! python scripts/lint/validate_docs.py 2>&1 | head -20; then
        echo -e "${RED}❌ Documentation validation failed${NC}"
        echo -e "${YELLOW}   Fix validation errors before committing${NC}"
        exit 1
    fi
fi

# 5. Check for large files (>5MB)
echo -e "${BLUE}Checking file sizes...${NC}"
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        SIZE=$(stat -f%z "$FILE" 2>/dev/null || stat -c%s "$FILE" 2>/dev/null || echo 0)
        if [ $SIZE -gt 5242880 ]; then
            SIZE_MB=$((SIZE / 1048576))
            echo -e "${RED}❌ Large file detected: $FILE (${SIZE_MB}MB)${NC}"
            echo -e "${RED}   Files >5MB should not be committed${NC}"
            echo -e "${YELLOW}   Use Git LFS or move to external storage${NC}"
            exit 1
        fi
    fi
done

# 6. Check for debug statements
echo -e "${BLUE}Checking for debug code...${NC}"
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        # Python: debugger, breakpoint()
        if echo "$FILE" | grep -qE '\.py$'; then
            if grep -qE '(import pdb|breakpoint\(\)|set_trace\(\))' "$FILE" 2>/dev/null; then
                echo -e "${YELLOW}⚠️  Debug code found in: $FILE${NC}"
                grep -nE '(import pdb|breakpoint\(\)|set_trace\(\))' "$FILE" || true
            fi
        fi

        # Go: fmt.Println for debugging
        if echo "$FILE" | grep -qE '\.go$'; then
            if grep -qE 'fmt\.Println.*DEBUG|fmt\.Printf.*DEBUG' "$FILE" 2>/dev/null; then
                echo -e "${YELLOW}⚠️  Debug print found in: $FILE${NC}"
            fi
        fi

        # JS/TS: console.log (non-test files)
        if echo "$FILE" | grep -qE '\.(js|ts|tsx|jsx)$' && ! echo "$FILE" | grep -qE '(test|spec)'; then
            if grep -qE 'console\.(log|debug)' "$FILE" 2>/dev/null; then
                echo -e "${YELLOW}⚠️  console.log found in: $FILE${NC}"
                echo -e "${YELLOW}   Consider using structured logger${NC}"
            fi
        fi
    fi
done

# 7. Run language-specific linters if available
STAGED_GO=$(echo "$STAGED_FILES" | grep '\.go$' || true)
if [ -n "$STAGED_GO" ] && command -v golangci-lint &> /dev/null; then
    echo -e "${BLUE}Running golangci-lint...${NC}"
    if ! golangci-lint run --new-from-rev=HEAD~ $STAGED_GO; then
        echo -e "${YELLOW}   Linter found issues (non-blocking)${NC}"
    fi
fi

STAGED_PY=$(echo "$STAGED_FILES" | grep '\.py$' || true)
if [ -n "$STAGED_PY" ] && command -v ruff &> /dev/null; then
    echo -e "${BLUE}Running ruff...${NC}"
    if ! ruff check $STAGED_PY; then
        echo -e "${YELLOW}   Linter found issues (non-blocking)${NC}"
    fi
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0
